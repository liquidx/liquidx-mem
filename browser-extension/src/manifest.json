{
  "manifest_version": 3,
  "name": "LiquidX Mem Extension",
  "version": "1.0.2",
  "description": "Save URLs and descriptions to mem.liquidx.net",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://mem.liquidx.net/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Save to Mem",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
