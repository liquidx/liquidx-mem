{
  "compilerOptions": {
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"]
    },
    "rootDir": "./",
    "outDir": "./dist",
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "importHelpers": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": false,
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["jest"],
    "lib": ["esnext", "dom", "dom.iterable", "scripthost"]
  },
  "include": [
    "src/tool.ts",
    "src/lib/**.server.ts",
    "src/lib/common/**.ts",
    "src/tools/**.ts",
    "src/lib/server/m3u8.d.ts",
    "src/lib/tool-shims.d.ts",
    "**.types.ts"
  ],
  "exclude": [
    "node_modules",
    "./node_modules/**",
    "vite.config.js",
    "tailwind.config.js",
    "svelte.config.js",
    "src/lib/**.svelte.ts",
    "src/lib/**.client.ts",
    "src/lib/components"
  ]
}
